import Std::Io::PrintLine;

struct ScanConfig {
    targetIp: *const char8;
    startPort: int32;
    endPort: int32;
}

func Main() -> int {
    PrintLine("[+] Initializing Blazing-Fast Rux Port Scanner...");
    
    let config = ScanConfig {
        targetIp: "127.0.0.1" as *const char8,
        startPort: 20,
        endPort: 1024
    };

    PrintLine("[*] Targeting Host across ports {} to {}", config.startPort, config.endPort);
    return 0;
}
